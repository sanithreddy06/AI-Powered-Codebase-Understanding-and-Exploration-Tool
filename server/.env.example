PORT=5000
LLM_PROVIDER=GROQ
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=your_gemini_api_key
GITHUB_TOKEN=your_github_token

# Password login users (email:password pairs, comma separated)
LOGIN_USERS=user1@example.com:pass123,user2@example.com:pass456

# Membership allowlist (must be present here to access analysis)
MEMBER_EMAILS=user1@example.com,user2@example.com

# Optional: increase timeout for long analyses
LLM_REQUEST_TIMEOUT_MS=300000
